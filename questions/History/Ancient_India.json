    "options": ["\u091a\u0940\u0928\u0940", "\u092e\u093f\u0938\u094d\u0930\u0940", "\u092d\u093e\u0930\u0924\u0940\u092f", "\u092f\u0942\u0928\u093e\u0928\u0940"],
    "correct": 2,
    "explanation": "\u0936\u0924\u0930\u0902\u091c, \u091c\u093f\u0938\u0947 \u092e\u0942\u0932 \u0930\u0942\u092a \u0938\u0947 \u091a\u0924\u0941\u0930\u0902\u0917 \u0915\u0939\u093e \u091c\u093e\u0924\u093e \u0925\u093e, \u0915\u0940 \u0909\u0924\u094d\u092a\u0924\u094d\u0924\u093f \u0917\u0941\u092a\u094d\u0924 \u0915\u093e\u0932 (\u0932\u0917\u092d\u0917 6\u0920\u0940 \u0936\u0924\u093e\u092c\u094d\u0926\u0940 \u0908.) \u0915\u0947 \u0926\u094c\u0930\u093e\u0928 \u092a\u094d\u0930\u093e\u091a\u0940\u0928 \u092d\u093e\u0930\u0924 \u092e\u0947\u0902 \u0939\u0941\u0908 \u092e\u093e\u0928\u0940 \u091c\u093e\u0924\u0940 \u0939\u0948, \u0907\u0938\u0938\u0947 \u092a\u0939\u0932\u0947 \u0915\u093f \u092f\u0939 \u092b\u093e\u0930\u0938 \u0914\u0930 \u0905\u0902\u0924\u0924\u0903 \u092f\u0942\u0930\u094b\u092a \u092e\u0947\u0902 \u092b\u0948\u0932\u093e\u0964"
  },
  {
    "question": "\u0928\u093f\u092e\u094d\u0928\u0932\u093f\u0916\u093f\u0924 \u092e\u0947\u0902 \u0938\u0947 \u0915\u094c\u0928-\u0938\u093e \u092a\u094d\u0930\u093e\u091a\u0940\u0928 \u092c\u0902\u0926\u0930\u0917\u093e\u0939 \u0926\u0915\u094d\u0937\u093f\u0923 \u092d\u093e\u0930\u0924 \u092e\u0947\u0902 \u0935\u094d\u092f\u093e\u092a\u093e\u0930 \u0915\u093e \u092a\u094d\u0930\u092e\u0941\u0916 \u0915\u0947\u0902\u0926\u094d\u0930 \u0925\u093e?",
    "options": ["\u0932\u094b\u0925\u0932", "\u0924\u093e\u092e\u094d\u0930\u0932\u093f\u092a\u094d\u0924\u093f", "\u092a\u0941\u0939\u093e\u0930 (\u0915\u093e\u0935\u0947\u0930\u0940\u092a\u091f\u094d\u091f\u093f\u0928\u092e)", "\u092d\u0921\u093c\u094c\u091a"],
    "correct": 2,
    "explanation": "\u092a\u0941\u0939\u093e\u0930, \u091c\u093f\u0938\u0947 \u0915\u093e\u0935\u0947\u0930\u0940\u092a\u091f\u094d\u091f\u093f\u0928\u092e \u092d\u0940 \u0915\u0939\u093e \u091c\u093e\u0924\u093e \u0939\u0948, \u0924\u092e\u093f\u0932\u0928\u093e\u0921\u0941 \u092e\u0947\u0902 \u090f\u0915 \u092a\u094d\u0930\u092e\u0941\u0916 \u092a\u094d\u0930\u093e\u091a\u0940\u0928 \u092c\u0902\u0926\u0930\u0917\u093e\u0939 \u0925\u093e \u091c\u094b \u0938\u0902\u0917\u092e \u0938\u093e\u0939\u093f\u0924\u094d\u092f \u092e\u0947\u0902 \u0909\u0932\u094d\u0932\u093f\u0916\u093f\u0924 \u0939\u0948 \u0914\u0930 \u091a\u094b\u0932 \u0930\u093e\u091c\u094d\u092f \u0915\u0940 \u0930\u093e\u091c\u0927\u093e\u0928\u0940 \u0924\u0925\u093e \u090f\u0915 \u092a\u094d\u0930\u092e\u0941\u0916 \u0935\u094d\u092f\u093e\u092a\u093e\u0930 \u0915\u0947\u0902\u0926\u094d\u0930 \u0925\u093e\u0964"
  },
  {
    "question": "\u092a\u094d\u0930\u093e\u091a\u0940\u0928 \u092d\u093e\u0930\u0924 \u092e\u0947\u0902 \u0938\u0940\u0916\u0928\u0947 \u0915\u0947 \u0938\u092c\u0938\u0947 \u092e\u0939\u093e\u0928 \u0915\u0947\u0902\u0926\u094d\u0930\u094b\u0902 \u092e\u0947\u0902 \u0938\u0947 \u090f\u0915, \u0928\u093e\u0932\u0902\u0926\u093e \u0935\u093f\u0936\u094d\u0935\u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f, \u0935\u0930\u094d\u0924\u092e\u093e\u0928 \u092e\u0947\u0902 \u0915\u093f\u0938 \u0930\u093e\u091c\u094d\u092f \u092e\u0947\u0902 \u0938\u094d\u0925\u093f\u0924 \u0925\u093e?",
    "options": ["\u0909\u0924\u094d\u0924\u0930 \u092a\u094d\u0930\u0926\u0947\u0936", "\u092c\u093f\u0939\u093e\u0930", "\u092a\u0936\u094d\u091a\u093f\u092e \u092c\u0902\u0917\u093e\u0932", "\u092e\u0927\u094d\u092f \u092a\u094d\u0930\u0926\u0947\u0936"],
    "correct": 1,
    "explanation": "\u0928\u093e\u0932\u0902\u0926\u093e \u0935\u093f\u0936\u094d\u0935\u0935\u093f\u0926\u094d\u092f\u093e\u0932\u092f \u0935\u0930\u094d\u0924\u092e\u093e\u0928 \u092c\u093f\u0939\u093e\u0930 \u0930\u093e\u091c\u094d\u092f \u092e\u0947\u0902 \u0938\u094d\u0925\u093f\u0924 \u0925\u093e\u0964 \u092f\u0939 \u0917\u0941\u092a\u094d\u0924 \u0915\u093e\u0932 \u0915\u0947 \u0926\u094c\u0930\u093e\u0928 \u0938\u094d\u0925\u093e\u092a\u093f\u0924 \u092c\u094c\u0926\u094d\u0927 \u0936\u093f\u0915\u094d\u0937\u093e \u0915\u093e \u090f
